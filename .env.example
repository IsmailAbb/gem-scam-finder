# Copy this file to `.env` and fill in the values.
# `.env` is gitignored - never commit real keys.

# Anthropic API key for the classifier.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides - defaults are fine for local dev.
# DATABASE_URL=sqlite:///data/gemscan.db
# CLASSIFICATION_MODEL=claude-sonnet-4-6
# REVIEW_REQUIRED_THRESHOLD=0.7

# Admin UI password (basic-auth gate on the review/publish endpoints).
ADMIN_PASSWORD=change-me
